+"""Unit tests for the pure (no-ffmpeg) parts of the core API."""
+from pozu_transcode import core
+from pozu_transcode.config import DEFAULT_BUCKETS, TranscodeConfig
+
+
+def _bucket(name):
+    return next(b for b in DEFAULT_BUCKETS if b.name == name)
+
+
+def test_even():
+    assert core.even(720) == 720
+    assert core.even(99) % 2 == 0
+    assert core.even(0.4) == 2  # floor of 2
+
+
+def test_pick_bucket_nearest():
+    assert core.pick_bucket(1.00, DEFAULT_BUCKETS).name == "sq"
+    assert core.pick_bucket(1.33, DEFAULT_BUCKETS).name == "4x3"
+    assert core.pick_bucket(1.78, DEFAULT_BUCKETS).name == "16x9"
+    # An extreme wide source still snaps to the widest available bucket.
+    assert core.pick_bucket(3.0, DEFAULT_BUCKETS).name == "16x9"
+
+
+def test_letterbox_exact_fit_no_padding():
+    lb = core.compute_letterbox(1920, 1080, _bucket("16x9"))  # scales to 960x540
+    assert (lb.active_w, lb.active_h, lb.pad_x, lb.pad_y) == (960, 540, 0, 0)
+
+
+def test_letterbox_no_upscale_pads_small_source():
+    lb = core.compute_letterbox(100, 100, _bucket("sq"))  # 720x720 canvas
+    assert (lb.active_w, lb.active_h) == (100, 100)
+    assert lb.pad_x == (720 - 100) // 2 and lb.pad_y == (720 - 100) // 2
+
+
+def test_letterbox_upscale_when_allowed():
+    lb = core.compute_letterbox(100, 100, _bucket("sq"), allow_upscale=True)
+    assert (lb.active_w, lb.active_h) == (720, 720)
+
+
+def _meta(w, h, fps=29.97):
+    return core.VideoMeta(width=w, height=h, fps_r=fps, fps_avg=fps,
+                          codec="h264", duration=10.0)
+
+
+def test_plan_encode_defaults():
+    plan = core.plan_encode(_meta(1920, 1080), TranscodeConfig())
+    assert plan.bucket.name == "16x9"
+    assert plan.fps == 30
+    assert plan.gop == 30  # 1s GOP at 30fps
+
+
+def test_plan_encode_keeps_source_fps():
+    plan = core.plan_encode(_meta(1920, 1080, fps=24.0),
+                            TranscodeConfig(target_fps=None))
+    assert plan.fps == 24
+
+
+def test_build_ffmpeg_command_has_fast_seek_flags():
+    plan = core.plan_encode(_meta(1920, 1080), TranscodeConfig())
+    cmd = core.build_ffmpeg_command("in.mp4", "out.mp4", plan, TranscodeConfig())
+    joined = " ".join(cmd)
+
+    assert "+faststart" in cmd
+    assert "scale=960:540" in joined and "pad=960:540" in joined
+    assert "scenecut=0:open-gop=0" in cmd
+    assert cmd[cmd.index("-g") + 1] == "30"
+    assert cmd[cmd.index("-crf") + 1] == "20"
+    assert cmd[cmd.index("-fps_mode") + 1] == "cfr"
