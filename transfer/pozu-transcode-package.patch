--- /dev/null
+++ b/src/pozu_transcode/cli.py
@@ -0,0 +1,177 @@
+"""rich-click command-line interface.
+
+Two transcode entry points -- ``single`` (one file) and ``batch`` (a directory) --
+share the same options and the same :mod:`pozu_transcode.core` logic. ``survey``
+reports resolutions/aspect ratios so you can choose buckets before transcoding.
+"""
+from __future__ import annotations
+
+from pathlib import Path
+from typing import Tuple
+
+import rich_click as click
+from rich.console import Console
+from rich.table import Table
+
+from . import __version__, core
+from .config import DEFAULT_BUCKETS, Bucket, TranscodeConfig
+
+click.rich_click.USE_RICH_MARKUP = True
+click.rich_click.SHOW_ARGUMENTS = True
+click.rich_click.GROUP_ARGUMENTS_OPTIONS = True
+
+console = Console()
+
+
+# ── shared option handling ──────────────────────────────────────────────────
+def _parse_buckets(raw: Tuple[str, ...]) -> list:
+    buckets = []
+    for item in raw:
+        try:
+            name, dims = item.split(":")
+            w, h = dims.lower().split("x")
+            buckets.append(Bucket(name, int(w), int(h)))
+        except ValueError as exc:
+            raise click.BadParameter(
+                f"invalid bucket {item!r}; expected NAME:WIDTHxHEIGHT, e.g. 16x9:960x540"
+            ) from exc
+    return buckets
+
+
+def encode_options(func):
+    """Attach the transcode knobs shared by ``single`` and ``batch``."""
+    options = [
+        click.option("--crf", type=int, default=20, show_default=True,
+                     help="x264 CRF quality (lower = better quality, larger files)."),
+        click.option("--preset", default="slow", show_default=True,
+                     help="x264 speed/efficiency preset."),
+        click.option("--gop-seconds", type=float, default=1.0, show_default=True,
+                     help="Keyframe interval in seconds (smaller = faster random seeks)."),
+        click.option("--fps", "target_fps", type=int, default=30, show_default=True,
+                     help="Force constant frame rate to this fps. Use [cyan]0[/] to keep each source's fps."),
+        click.option("--allow-upscale/--no-upscale", default=False, show_default=True,
+                     help="Allow upscaling sources smaller than their canvas."),
+        click.option("--bucket", "buckets_raw", multiple=True, metavar="NAME:WxH",
+                     help="Override aspect-ratio buckets (repeatable), e.g. [cyan]--bucket 16x9:960x540[/]."),
+    ]
+    for option in reversed(options):
+        func = option(func)
+    return func
+
+
+def _build_config(crf, preset, gop_seconds, target_fps, allow_upscale, buckets_raw) -> TranscodeConfig:
+    return TranscodeConfig(
+        buckets=_parse_buckets(buckets_raw) if buckets_raw else list(DEFAULT_BUCKETS),
+        target_fps=target_fps or None,  # 0 -> keep source fps
+        crf=crf,
+        preset=preset,
+        gop_seconds=gop_seconds,
+        allow_upscale=allow_upscale,
+    )
+
+
+def _print_entry(entry: core.ManifestEntry) -> None:
+    table = Table(show_header=False, box=None, pad_edge=False)
+    table.add_row("output", entry.out_path)
+    table.add_row("bucket", f"{entry.bucket} ({entry.canvas_w}x{entry.canvas_h})")
+    table.add_row("source", f"{entry.src_w}x{entry.src_h}")
+    table.add_row("active", f"{entry.active_w}x{entry.active_h} (pad {entry.pad_x},{entry.pad_y})")
+    table.add_row("fps", str(entry.fps))
+    table.add_row("frames", str(entry.frame_count))
+    console.print(table)
+
+
+# ── commands ────────────────────────────────────────────────────────────────
+@click.group(context_settings={"help_option_names": ["-h", "--help"]})
+@click.version_option(__version__, prog_name="pozu-transcode")
+def cli() -> None:
+    """Canonical, AR-bucketed, fast-seek H.264 transcoding for [bold]Pozu[/].
+
+    Outputs are faststart, constant-frame-rate H.264 with a closed ~1s GOP --
+    watchable as normal movies, but tuned for fast random-frame seeking. Each
+    source is letterbox-padded (never stretched or cropped) into its nearest
+    aspect-ratio canvas.
+    """
+
+
+@cli.command(short_help="Transcode a single video file.")
+@click.argument("input", type=click.Path(exists=True, dir_okay=False, path_type=Path))
+@click.argument("output", type=click.Path(dir_okay=False, path_type=Path))
+@encode_options
+def single(input: Path, output: Path, **opts) -> None:
+    """Transcode one [cyan]INPUT[/] video into [cyan]OUTPUT[/] (an .mp4)."""
+    config = _build_config(**opts)
+    with console.status(f"Transcoding {input} ..."):
+        entry = core.transcode(input, output, config)
+    console.print(f"[green]✓[/] {input} [dim]->[/] {output}")
+    _print_entry(entry)
+
+
+@cli.command(short_help="Transcode every video in a directory.")
+@click.argument("input_dir", type=click.Path(exists=True, file_okay=False, path_type=Path))
+@click.argument("output_dir", type=click.Path(file_okay=False, path_type=Path))
+@encode_options
+def batch(input_dir: Path, output_dir: Path, **opts) -> None:
+    """Transcode all videos under [cyan]INPUT_DIR[/] into [cyan]OUTPUT_DIR[/].
+
+    Writes one .mp4 per source plus a [cyan]manifest.json[/] describing every
+    output (bucket, canvas, active region, fps, frame count).
+    """
+    config = _build_config(**opts)
+
+    def on_done(src: Path, entry: core.ManifestEntry) -> None:
+        console.print(
+            f"[green]✓[/] {src} [dim]->[/] {entry.out_path} "
+            f"[cyan]\\[{entry.bucket}][/]"
+        )
+
+    entries = core.transcode_batch(input_dir, output_dir, config, on_done=on_done)
+    if not entries:
+        console.print(f"[yellow]No videos found under {input_dir}.[/]")
+        return
+    console.print(
+        f"\n[bold green]Transcoded {len(entries)} videos[/] "
+        f"[dim]->[/] {output_dir / 'manifest.json'}"
+    )
+
+
+@cli.command(short_help="Report resolutions and aspect ratios (no transcoding).")
+@click.argument("input_dir", type=click.Path(exists=True, file_okay=False, path_type=Path))
+@click.option("--bucket", "buckets_raw", multiple=True, metavar="NAME:WxH",
+              help="Buckets to assign against (repeatable); defaults to the built-in set.")
+def survey(input_dir: Path, buckets_raw: Tuple[str, ...]) -> None:
+    """Probe every video under [cyan]INPUT_DIR[/] and print an aspect-ratio histogram.
+
+    Run this first to confirm the bucket presets fit your corpus.
+    """
+    buckets = _parse_buckets(buckets_raw) if buckets_raw else list(DEFAULT_BUCKETS)
+    paths = list(core.iter_videos(input_dir, TranscodeConfig().video_extensions))
+    if not paths:
+        console.print(f"[yellow]No videos found under {input_dir}.[/]")
+        return
+
+    results = core.survey(paths)
+    table = Table(title=f"{len(results)} videos under {input_dir}")
+    for col in ("file", "resolution", "AR", "codec", "fps", "bucket"):
+        table.add_column(col)
+    for path, meta in results:
+        bucket = core.pick_bucket(meta.aspect_ratio, buckets)
+        table.add_row(
+            str(path),
+            f"{meta.width}x{meta.height}",
+            f"{meta.aspect_ratio:.2f}",
+            meta.codec,
+            f"{meta.fps_r:.2f}" + (" [red]VFR[/]" if meta.is_vfr else ""),
+            bucket.name,
+        )
+    console.print(table)
+
+    hist = core.aspect_histogram([m for _, m in results])
+    console.print(
+        "AR histogram: "
+        + ", ".join(f"[cyan]{ar:.2f}[/]: {n}" for ar, n in hist.items())
+    )
+
+
+if __name__ == "__main__":  # pragma: no cover
+    cli()
diff --git a/src/pozu_transcode/config.py b/src/pozu_transcode/config.py
