--- /dev/null
+++ b/src/pozu_transcode/config.py
@@ -0,0 +1,49 @@
+"""Configuration objects for the transcoding pipeline."""
+from __future__ import annotations
+
+from dataclasses import dataclass, field
+from typing import List, Optional, Tuple
+
+
+@dataclass(frozen=True)
+class Bucket:
+    """A fixed output canvas that videos of a similar aspect ratio are padded into."""
+
+    name: str
+    width: int
+    height: int
+
+    @property
+    def aspect_ratio(self) -> float:
+        return self.width / self.height
+
+
+# Default canvases: ~0.52 MP each, even dimensions, spanning common aspect ratios.
+# Tune these to your corpus (run `pozu-transcode survey ...` first).
+DEFAULT_BUCKETS: Tuple[Bucket, ...] = (
+    Bucket("sq", 720, 720),    # 1.00
+    Bucket("4x3", 832, 624),   # 1.33
+    Bucket("16x9", 960, 540),  # 1.78
+)
+
+VIDEO_EXTENSIONS: Tuple[str, ...] = (".mp4", ".mov", ".avi", ".mkv")
+
+
+@dataclass
+class TranscodeConfig:
+    """Knobs shared by the single-file and batch entry points.
+
+    The defaults encode every output as faststart, constant-frame-rate H.264 with a
+    closed ~1s GOP -- watchable as a normal movie, but tuned for fast random-frame
+    seeking. Each source is letterbox-padded (never stretched or cropped) into its
+    nearest-aspect-ratio :class:`Bucket`.
+    """
+
+    buckets: List[Bucket] = field(default_factory=lambda: list(DEFAULT_BUCKETS))
+    target_fps: Optional[int] = 30  # force CFR to this; None keeps each source's fps
+    crf: int = 20
+    preset: str = "slow"
+    gop_seconds: float = 1.0  # keyframe interval -> fast seeks, small size cost
+    allow_upscale: bool = False  # don't invent detail in small sources by default
+    audio_bitrate: str = "128k"
+    video_extensions: Tuple[str, ...] = VIDEO_EXTENSIONS
diff --git a/src/pozu_transcode/core.py b/src/pozu_transcode/core.py
new file mode 100644
index 0000000..cf97d5c
--- /dev/null
+++ b/src/pozu_transcode/core.py
@@ -0,0 +1,280 @@
+"""Core, framework-agnostic transcoding API.
+
+This module knows nothing about the CLI; it operates on plain paths and returns
+plain data, so both the ``single`` and ``batch`` commands -- and any external
+caller -- share the exact same logic.
+"""
+from __future__ import annotations
+
+import json
+import math
+import subprocess
+from collections import Counter
+from dataclasses import asdict, dataclass
+from pathlib import Path
+from typing import Callable, Dict, Iterator, List, Optional, Sequence, Tuple, Union
+
+from .config import Bucket, TranscodeConfig
+
+PathLike = Union[str, Path]
+
+
+class FFmpegError(RuntimeError):
+    """Raised when ffmpeg/ffprobe is missing or returns a non-zero exit code."""
+
+
+# ── data ────────────────────────────────────────────────────────────────────
+@dataclass
+class VideoMeta:
+    width: int
+    height: int
+    fps_r: float  # nominal (r_frame_rate)
+    fps_avg: float  # measured average
+    codec: str
+    duration: float
+
+    @property
+    def aspect_ratio(self) -> float:
+        return self.width / self.height
+
+    @property
+    def is_vfr(self) -> bool:
+        return self.fps_avg > 0 and abs(self.fps_r - self.fps_avg) > 0.01
+
+
+@dataclass
+class Letterbox:
+    """How a source is scaled and centered inside a bucket canvas."""
+
+    active_w: int
+    active_h: int
+    pad_x: int
+    pad_y: int
+
+
+@dataclass
+class EncodePlan:
+    bucket: Bucket
+    letterbox: Letterbox
+    fps: int
+    gop: int
+
+    @property
+    def vf(self) -> str:
+        """The ffmpeg ``-vf`` filter chain: uniform scale, then centered pad."""
+        lb, b = self.letterbox, self.bucket
+        return (
+            f"scale={lb.active_w}:{lb.active_h}:flags=lanczos,"
+            f"pad={b.width}:{b.height}:{lb.pad_x}:{lb.pad_y}:color=black,setsar=1"
+        )
+
+
+@dataclass
+class ManifestEntry:
+    video_id: str
+    src_path: str
+    out_path: str
+    src_w: int
+    src_h: int
+    frame_count: int
+    bucket: str
+    canvas_w: int
+    canvas_h: int
+    active_w: int
+    active_h: int
+    pad_x: int
+    pad_y: int
+    fps: int
+
+    def to_dict(self) -> Dict[str, object]:
+        return asdict(self)
+
+
+# ── ffprobe / ffmpeg ────────────────────────────────────────────────────────
+def _run(cmd: Sequence[str], *, capture: bool = False) -> str:
+    try:
+        result = subprocess.run(
+            list(cmd), capture_output=True, text=True, check=True
+        )
+    except FileNotFoundError as exc:  # ffmpeg/ffprobe not installed
+        raise FFmpegError(f"Command not found: {cmd[0]!r} (is ffmpeg installed?)") from exc
+    except subprocess.CalledProcessError as exc:
+        raise FFmpegError(f"{cmd[0]} failed:\n{exc.stderr}") from exc
+    return result.stdout if capture else ""
+
+
+def _rate(value: str) -> float:
+    """Parse an ffprobe rational like ``30000/1001`` into a float."""
+    try:
+        num, _, den = value.partition("/")
+        d = float(den) if den else 1.0
+        return float(num) / d if d else 0.0
+    except (ValueError, ZeroDivisionError):
+        return 0.0
+
+
+def probe(path: PathLike) -> VideoMeta:
+    """Read width/height/fps/codec/duration of the first video stream."""
+    out = _run(
+        [
+            "ffprobe", "-v", "error", "-select_streams", "v:0",
+            "-show_entries",
+            "stream=width,height,r_frame_rate,avg_frame_rate,codec_name",
+            "-show_entries", "format=duration",
+            "-of", "json", str(path),
+        ],
+        capture=True,
+    )
+    data = json.loads(out)
+    streams = data.get("streams") or []
+    if not streams:
+        raise FFmpegError(f"No video stream found in {path}")
+    st = streams[0]
+    return VideoMeta(
+        width=int(st["width"]),
+        height=int(st["height"]),
+        fps_r=_rate(st.get("r_frame_rate", "0/1")),
+        fps_avg=_rate(st.get("avg_frame_rate", "0/1")),
+        codec=st.get("codec_name", "?"),
+        duration=float(data.get("format", {}).get("duration", 0.0)),
+    )
+
+
+# ── geometry ────────────────────────────────────────────────────────────────
+def even(x: float) -> int:
+    """Round to the nearest even integer >= 2 (yuv420p requires even dims)."""
+    return max(2, int(round(x / 2)) * 2)
+
+
+def pick_bucket(aspect_ratio: float, buckets: Sequence[Bucket]) -> Bucket:
+    """Choose the bucket whose AR is nearest in log-space (minimizes bar area)."""
+    return min(buckets, key=lambda b: abs(math.log(aspect_ratio / b.aspect_ratio)))
+
+
+def compute_letterbox(
+    src_w: int, src_h: int, bucket: Bucket, allow_upscale: bool = False
+) -> Letterbox:
+    """Uniformly scale a source to fit a bucket canvas, then center it."""
+    scale = min(bucket.width / src_w, bucket.height / src_h)
+    if not allow_upscale:
+        scale = min(scale, 1.0)
+    aw, ah = even(src_w * scale), even(src_h * scale)
+    return Letterbox(aw, ah, (bucket.width - aw) // 2, (bucket.height - ah) // 2)
+
+
+def plan_encode(
+    meta: VideoMeta, config: TranscodeConfig, bucket: Optional[Bucket] = None
+) -> EncodePlan:
+    """Resolve the bucket, letterbox, output fps, and keyframe interval."""
+    bucket = bucket or pick_bucket(meta.aspect_ratio, config.buckets)
+    letterbox = compute_letterbox(meta.width, meta.height, bucket, config.allow_upscale)
+    fps = config.target_fps if config.target_fps else max(1, round(meta.fps_r))
+    gop = max(1, round(fps * config.gop_seconds))
+    return EncodePlan(bucket=bucket, letterbox=letterbox, fps=fps, gop=gop)
+
+
+def build_ffmpeg_command(
+    src: PathLike, dst: PathLike, plan: EncodePlan, config: TranscodeConfig
+) -> List[str]:
+    """Build the ffmpeg invocation for a single transcode (no I/O performed)."""
+    return [
+        "ffmpeg", "-y", "-i", str(src),
+        "-vf", plan.vf,
+        "-c:v", "libx264", "-profile:v", "high", "-pix_fmt", "yuv420p",
+        "-crf", str(config.crf), "-preset", config.preset,
+        "-g", str(plan.gop), "-keyint_min", str(plan.gop),
+        "-x264-params", "scenecut=0:open-gop=0", "-bf", "2",
+        "-fps_mode", "cfr", "-r", str(plan.fps),
+        "-c:a", "aac", "-b:a", config.audio_bitrate,
+        "-movflags", "+faststart",
+        str(dst),
+    ]
+
+
+# ── transcode ───────────────────────────────────────────────────────────────
+def transcode(
+    src: PathLike,
+    dst: PathLike,
+    config: Optional[TranscodeConfig] = None,
+    *,
+    bucket: Optional[Bucket] = None,
+) -> ManifestEntry:
+    """Transcode one file into the canonical space and return its manifest entry."""
+    config = config or TranscodeConfig()
+    src, dst = Path(src), Path(dst)
+    dst.parent.mkdir(parents=True, exist_ok=True)
+
+    meta = probe(src)
+    plan = plan_encode(meta, config, bucket)
+    _run(build_ffmpeg_command(src, dst, plan, config))
+
+    out_meta = probe(dst)
+    frame_count = round(out_meta.duration * plan.fps)
+    return ManifestEntry(
+        video_id=dst.name,
+        src_path=str(src),
+        out_path=str(dst),
+        src_w=meta.width,
+        src_h=meta.height,
+        frame_count=frame_count,
+        bucket=plan.bucket.name,
+        canvas_w=plan.bucket.width,
+        canvas_h=plan.bucket.height,
+        active_w=plan.letterbox.active_w,
+        active_h=plan.letterbox.active_h,
+        pad_x=plan.letterbox.pad_x,
+        pad_y=plan.letterbox.pad_y,
+        fps=plan.fps,
+    )
+
+
+def iter_videos(root: PathLike, extensions: Sequence[str]) -> Iterator[Path]:
+    """Yield video files under ``root`` (recursive), sorted for determinism."""
+    exts = tuple(e.lower() for e in extensions)
+    for path in sorted(Path(root).rglob("*")):
+        if path.is_file() and path.suffix.lower() in exts:
+            yield path
+
+
+def transcode_batch(
+    in_dir: PathLike,
+    out_dir: PathLike,
+    config: Optional[TranscodeConfig] = None,
+    *,
+    on_start: Optional[Callable[[Path], None]] = None,
+    on_done: Optional[Callable[[Path, ManifestEntry], None]] = None,
+) -> List[ManifestEntry]:
+    """Transcode every video under ``in_dir`` and write ``out_dir/manifest.json``."""
+    config = config or TranscodeConfig()
+    out_dir = Path(out_dir)
+    out_dir.mkdir(parents=True, exist_ok=True)
+
+    entries: List[ManifestEntry] = []
+    for src in iter_videos(in_dir, config.video_extensions):
+        if on_start:
+            on_start(src)
+        entry = transcode(src, out_dir / (src.stem + ".mp4"), config)
+        entries.append(entry)
+        if on_done:
+            on_done(src, entry)
+
+    write_manifest(entries, out_dir / "manifest.json")
+    return entries
+
+
+def write_manifest(entries: Sequence[ManifestEntry], path: PathLike) -> None:
+    Path(path).write_text(
+        json.dumps([e.to_dict() for e in entries], indent=2), encoding="utf-8"
+    )
+
+
+# ── survey ──────────────────────────────────────────────────────────────────
+def survey(paths: Sequence[PathLike]) -> List[Tuple[Path, VideoMeta]]:
+    """Probe each path, returning (path, metadata) pairs."""
+    return [(Path(p), probe(p)) for p in paths]
+
+
+def aspect_histogram(metas: Sequence[VideoMeta], ndigits: int = 2) -> Dict[float, int]:
+    """Count videos by rounded aspect ratio -- use it to choose your buckets."""
+    counts = Counter(round(m.aspect_ratio, ndigits) for m in metas)
+    return dict(sorted(counts.items()))
